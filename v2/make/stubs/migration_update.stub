	"github.com/gtkit/migrate/v2/migration"
)

func init() {
	up := func(db *gorm.DB) error {
		return db.AutoMigrate(&{{ModelPackageName}}.{{StructName}}{})
	}

	down := func(db *gorm.DB) error {
		return migration.Irreversible("fill in the down migration for {{FileName}} manually")
	}

	migration.Add("{{FileName}}", up, down)
}
